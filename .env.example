# =========================================================================
# SocioHub — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =========================================================================

# --- Supabase (Lovable Cloud) ---------------------------------------------
# Project ref and publishable (anon) key are safe in the client bundle.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Server-side mirrors (read by createServerFn / server routes).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
SUPABASE_PROJECT_ID=your-project-ref

# Service role key — SERVER ONLY. Never expose to the client. Managed by
# Lovable Cloud; do not set this manually in committed env files.
# SUPABASE_SERVICE_ROLE_KEY=managed-by-lovable-cloud

# --- Firebase (push notifications + phone OTP) ----------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VAPID public key for web push (Firebase Cloud Messaging).
VITE_FIREBASE_VAPID_KEY=

# --- Analytics (optional) -------------------------------------------------
# Google Analytics 4 measurement ID, e.g. G-XXXXXXX.
VITE_GA_MEASUREMENT_ID=
# Meta (Facebook) Pixel ID, numeric.
VITE_META_PIXEL_ID=

# --- Error monitoring (optional) ------------------------------------------
# Sentry browser DSN. Leave blank to disable Sentry.
VITE_SENTRY_DSN=

# --- Razorpay (payments, server-side) -------------------------------------
# RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET are runtime secrets — add via the
# Lovable Cloud secret manager, NOT in this file.
